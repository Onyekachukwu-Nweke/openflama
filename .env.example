# OpenFlama Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://openflama:openflama@localhost:5432/openflama

# Session secret for Express sessions (required)
SESSION_SECRET=change_me_to_a_random_string

# Server port (optional, defaults to 5000)
# PORT=5000

# Node environment (optional, defaults to development)
# NODE_ENV=development
